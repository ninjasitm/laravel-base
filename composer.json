{
	"name": "nitm/laravel-base",
	"description": "Laravel packages for NITM",
	"type": "laravel-helpers",
	"license": "MIT",
	"authors": [
		{
			"name": "Malcolm Paul",
			"email": "malcolm@ninjasitm.com"
		}
	],
	"support": {
		"issues": "https://gitlab.com/nitm/laravel-base/issues",
		"docs": "https://gitlab.com/nitm/laravel-base/wiki",
		"source": "https://gitlab.com/nitm/laravel-base"
	},
	"minimum-stability": "dev",
	"prefer-stable": true,
	"require": {
		"php": "^8.1|^8.2|^8.3",
		"laravel/framework": "^10.0|^11.0",
		"spatie/laravel-activitylog": "^4.12",
		"vinkla/hashids": "^11.0|^12.0"
	},
	"suggest": {
		"mad-web/laravel-social-auth": "To support social auth",
		"infyomlabs/laravel-generator": "To support easy  scaffolding",
		"infyomlabs/swagger-generator": "To support swagger annotations for models"
	},
	"require-dev": {
		"fakerphp/faker": "^1.14.0",
		"laravel/pint": "^1.4",
		"orchestra/testbench": "^8.37|^9.16",
		"phpunit/phpunit": "^10.5|^11.0",
		"phpdocumentor/reflection-docblock": "*",
		"symfony/mime": "^6.2|^7.0"
	},
	"autoload": {
		"psr-4": {
			"Nitm\\Content\\": "Content/src",
			"Nitm\\Api\\": "Api/src",
			"Nitm\\Helpers\\": "Helpers/src",
			"Nitm\\Testing\\": "Testing/src",
			"Nitm\\Content\\Database\\Factories\\": "Content/src/Database/Factories/"
		}
	},
	"autoload-dev": {
		"psr-4": {
			"Tests\\": "tests/"
		}
	},
	"extra": {
		"laravel": {
			"providers": [
				"Nitm\\Content\\NitmContentServiceProvider",
				"Nitm\\Api\\NitmApiServiceProvider"
			]
		}
	}
}
